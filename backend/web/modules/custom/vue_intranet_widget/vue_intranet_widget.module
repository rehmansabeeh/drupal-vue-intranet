<?php

/**
 * Implements hook_library_info_alter().
 */
function vue_intranet_widget_library_info_alter(&$libraries, $extension) {
  if ($extension === 'vue_intranet_widget' && isset($libraries['vue_app'])) {
    
    // We use a 1-second timeout so it doesn't slow down the page
    $connection = @fsockopen('host.docker.internal', 5173, $errno, $errstr, 1);

    if ($connection) {
      \Drupal::messenger()->addStatus('Vite Found! Development Mode Active.');
      
      // Remove production paths
      unset($libraries['vue_app']['js']['assets/index.js']);
      unset($libraries['vue_app']['css']['theme']['assets/index.css']);

      // Inject Development paths (Browser still uses localhost)
      $libraries['vue_app']['js']['http://localhost:5173/@vite/client'] = ['type' => 'external', 'attributes' => ['type' => 'module']];
      $libraries['vue_app']['js']['http://localhost:5173/src/main.ts'] = ['type' => 'external', 'attributes' => ['type' => 'module']];
      
      fclose($connection);
    }
  }
}